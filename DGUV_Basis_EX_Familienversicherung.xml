<?xml version="1.0" encoding="utf-8"?>
<StructureDefinition xmlns="http://hl7.org/fhir">
  <id value="DGUV-Basis-EX-Familienversicherung" />
  <url value="http://fhir.dguv.de/Basis/Extension/DGUV-Basis-EX-Familienversicherung" />
  <version value="1.5" />
  <name value="DGUV_Basis_EX_Familienversicherung" />
  <title value="Familienversicherung (Erweiterung)" />
  <status value="draft" />
  <publisher value="Deutsche Gesetzliche Unfallversicherung e.V. (DGUV)" />
  <description value="Diese Extension ermöglicht die Beschreibung des Versicherungsverhältnisses eines Patienten durch Kennzeichnung als selbst oder familienversichert und im letzteren Fall die Angabe des Namens des eigentlich Versicherten." />
  <fhirVersion value="4.0.1" />
  <kind value="complex-type" />
  <abstract value="false" />
  <context>
    <type value="element" />
    <expression value="Coverage" />
  </context>
  <type value="Extension" />
  <baseDefinition value="http://hl7.org/fhir/StructureDefinition/Extension" />
  <derivation value="constraint" />
  <differential>
    <element id="Extension.extension">
      <path value="Extension.extension" />
      <min value="1" />
      <max value="2" />
    </element>
    <element id="Extension.extension:Familienversichert">
      <path value="Extension.extension" />
      <sliceName value="Familienversichert" />
      <short value="Beschreibung des Patientenverhältnisses zur Versicherung" />
      <min value="1" />
      <max value="1" />
    </element>
    <element id="Extension.extension:Familienversichert.extension">
      <path value="Extension.extension.extension" />
      <max value="0" />
    </element>
    <element id="Extension.extension:Familienversichert.url">
      <path value="Extension.extension.url" />
      <fixedUri value="Familienversichert" />
    </element>
    <element id="Extension.extension:Familienversichert.value[x]">
      <path value="Extension.extension.value[x]" />
      <short value="Kennzeichnung als familien- (true) oder selbstversichert (false)" />
      <min value="1" />
      <type>
        <code value="boolean" />
      </type>
    </element>
    <element id="Extension.extension:Mitgliedsname">
      <path value="Extension.extension" />
      <sliceName value="Mitgliedsname" />
      <short value="Versicherter bei Familien(mit)versicherung des Patienten" />
      <max value="1" />
    </element>
    <element id="Extension.extension:Mitgliedsname.extension">
      <path value="Extension.extension.extension" />
      <max value="0" />
    </element>
    <element id="Extension.extension:Mitgliedsname.url">
      <path value="Extension.extension.url" />
      <fixedUri value="Mitgliedsname" />
    </element>
    <element id="Extension.extension:Mitgliedsname.value[x]">
      <path value="Extension.extension.value[x]" />
      <short value="Name des Versicherten bei Familien(mit)versicherung des Patienten" />
      <comment value="Nur wenn in Familienversichert.value[x] &quot;true&quot; eingetragen ist, muss hier zwingend der Name des eigentlich Versicherten angegeben werden." />
      <min value="1" />
      <type>
        <code value="string" />
      </type>
    </element>
    <element id="Extension.url">
      <path value="Extension.url" />
      <fixedUri value="http://fhir.dguv.de/Basis/Extension/DGUV-Basis-EX-Familienversicherung" />
    </element>
    <element id="Extension.value[x]">
      <path value="Extension.value[x]" />
      <max value="0" />
    </element>
  </differential>
</StructureDefinition>