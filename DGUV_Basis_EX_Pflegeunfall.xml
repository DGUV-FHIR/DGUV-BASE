  <description value="Diese Extension ermöglicht die Kennzeichnung eines Unfallereignisses als Pflegeunfall und in diesem Fall die Referenzierung auf die Pflegekasse der pflegebedürftigen Person." />
  <fhirVersion value="4.0.1" />
  <kind value="complex-type" />
  <abstract value="false" />
  <context>
    <type value="element" />
    <expression value="Observation" />
  </context>
  <type value="Extension" />
  <baseDefinition value="http://hl7.org/fhir/StructureDefinition/Extension" />
  <derivation value="constraint" />
  <differential>
    <element id="Extension.extension">
      <path value="Extension.extension" />
      <min value="1" />
      <max value="2" />
    </element>
    <element id="Extension.extension:Pflegeunfall">
      <path value="Extension.extension" />
      <sliceName value="Pflegeunfall" />
      <short value="Kennzeichnung eines Unfalls im Rahmen von Pflegetätigkeit" />
      <min value="1" />
      <max value="1" />
    </element>
    <element id="Extension.extension:Pflegeunfall.extension">
      <path value="Extension.extension.extension" />
      <max value="0" />
    </element>
    <element id="Extension.extension:Pflegeunfall.url">
      <path value="Extension.extension.url" />
      <fixedUri value="Pflegeunfall" />
    </element>
    <element id="Extension.extension:Pflegeunfall.value[x]">
      <path value="Extension.extension.value[x]" />
      <short value="Konkrete Kennzeichnung als Pflegeunfall (true) oder Nicht-Pflegeunfall (false)" />
      <min value="1" />
      <type>
        <code value="boolean" />
      </type>
    </element>
    <element id="Extension.extension:Pflegekasse">
      <path value="Extension.extension" />
      <sliceName value="Pflegekasse" />
      <short value="Pflegekasse der pflegebedürftigen Person im Fall eines Pflegeunfalls" />
      <comment value="Bei Pflegeunfall Pflegekasse der pflegebedürftigen Person" />
      <max value="1" />
    </element>
    <element id="Extension.extension:Pflegekasse.extension">
      <path value="Extension.extension.extension" />
      <max value="0" />
    </element>
    <element id="Extension.extension:Pflegekasse.url">
      <path value="Extension.extension.url" />
