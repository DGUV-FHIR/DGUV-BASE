      <min value="1" />
      <type>
        <code value="Reference" />
      </type>
    </element>
    <element id="Extension.extension:Pflegekasse.value[x].reference">
      <path value="Extension.extension.value[x].reference" />
      <short value="Konkreter Verweis auf die Pflegekasse" />
      <min value="1" />
    </element>
    <element id="Extension.url">
      <path value="Extension.url" />
      <fixedUri value="http://fhir.dguv.de/Basis/Extension/DGUV-Basis-EX-Pflegeunfall" />
