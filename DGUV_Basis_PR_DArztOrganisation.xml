<?xml version="1.0" encoding="utf-8"?>
<StructureDefinition xmlns="http://hl7.org/fhir">
  <url value="http://fhir.dguv.de/Basis/Organization/DGUV-Basis-PR-DArztOrganisation" />
  <version value="1.5" />
  <name value="DGUV_Basis_PR_DArztOrganisation" />
  <title value="D-Arzt Organisation" />
  <status value="draft" />
  <publisher value="Deutsche Gesetzliche Unfallversicherung e.V. (DGUV)" />
  <description value="Dieses Profil stellt die Einrichtung dar, der der D-Arzt zugeordnet ist." />
  <fhirVersion value="4.0.1" />
  <kind value="resource" />
  <abstract value="false" />
  <type value="Organization" />
  <baseDefinition value="http://fhir.dguv.de/Basis/Organization/DGUV-Basis-PR-BehandelndeEinrichtung" />
  <derivation value="constraint" />
  <differential>
    <element id="Organization.type.coding:IHE-Code">
      <path value="Organization.type.coding" />
      <sliceName value="IHE-Code" />
      <definition value="Hier wird der Typus der Einrichtung anhand eines Codes aus dem Codesystem IHE Deutschland e.V. angegeben." />
    </element>
    <element id="Organization.type.coding:HL7-Fachschluesselgruppe">
      <path value="Organization.type.coding" />
      <sliceName value="HL7-Fachschluesselgruppe" />
      <definition value="Hier wird die Fachrichtung/Fachabteilung anhand eines Codes aus dem Codesystem 'Fachabteilungsschlüssel' der HL7 Basis Deutschland angegeben." />
    </element>
    <element id="Organization.type.coding:HL7-Fachschluesselgruppe-erweitert">
      <path value="Organization.type.coding" />
      <sliceName value="HL7-Fachschluesselgruppe-erweitert" />
      <definition value="Hier wird die Fachrichtung/Fachabteilung anhand eines Codes aus dem Codesystem &quot;FachabteilungsschlüsselErweitert&quot; der HL7 Basis Deutschland angegeben." />
    </element>
    <element id="Organization.contact">
      <path value="Organization.contact" />
      <short value="Ansprechpartner für Rückfragen" />
    </element>
    <element id="Organization.contact.extension:NichtAerztlicherKontakt">
      <path value="Organization.contact.extension" />
      <sliceName value="NichtAerztlicherKontakt" />
      <short value="Kennzeichnung Ansprechpartner als (nicht-)ärztlichen Kontakt" />
      <type>
        <code value="Extension" />
        <profile value="http://fhir.dguv.de/Basis/Extension/DGUV-Basis-EX-NichtAerztlicherAnsprechpartner" />
      </type>
      <isModifier value="false" />
    </element>
    <element id="Organization.contact.extension:NichtAerztlicherKontakt.extension:NichtAerztlicherKontakt">
      <path value="Organization.contact.extension.extension" />
      <sliceName value="NichtAerztlicherKontakt" />
      <short value="Kennzeichnung Ansprechpartner als (nicht-)ärztlichen Kontakt" />
    </element>
    <element id="Organization.contact.extension:NichtAerztlicherKontakt.extension:NichtAerztlicherKontakt.value[x]">
      <path value="Organization.contact.extension.extension.value[x]" />
      <short value="Kennzeichnung Ansprechpartner als nicht-ärztlichen (true) oder ärztlichen (false) Kontakt" />
    </element>
    <element id="Organization.contact.extension:NichtAerztlicherKontakt.extension:Funktionseinheit">
      <path value="Organization.contact.extension.extension" />
      <sliceName value="Funktionseinheit" />
      <short value="Funktionseinheit des nicht-ärztlichen Ansprechpartners" />
    </element>
    <element id="Organization.contact.extension:NichtAerztlicherKontakt.extension:Funktionseinheit.value[x]">
      <path value="Organization.contact.extension.extension.value[x]" />
      <short value="Konkrete Funktionseinheit des nicht-ärztlichen Ansprechpartners als Freitext" />
    </element>
    <element id="Organization.contact.name">
      <path value="Organization.contact.name" />
      <short value="Name Ansprechpartner für Rückfragen" />
    </element>
    <element id="Organization.contact.telecom">
      <path value="Organization.contact.telecom" />
      <short value="Angaben zu bestehenden Kontaktmöglichkeiten (Telefon, Fax, E-Mail usw.)" />
      <comment value="Kontaktmöglichkeiten hier des Ansprechpartners für Rückfragen" />
    </element>
  </differential>
</StructureDefinition>